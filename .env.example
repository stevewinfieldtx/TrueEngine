# ============================================
# TrueEngine Configuration
# ============================================
PORT=8100

# OpenRouter (ALL LLM calls)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model assignments
ANALYSIS_MODEL=qwen/qwen-2.5-72b-instruct
CONTENT_MODEL=meta-llama/llama-3.1-70b-instruct
EMBEDDING_MODEL=qwen/qwen3-embedding-8b

# YouTube Data API v3
YOUTUBE_API_KEY=

# Transcription (Groq Whisper)
GROQ_API_KEY=

# ElevenLabs (voice cloning)
ELEVENLABS_API_KEY=

# Qdrant (vector search) — get free tier at https://cloud.qdrant.io
QDRANT_URL=
QDRANT_API_KEY=
EMBEDDING_DIMENSION=768

# Processing
CHUNK_SIZE=500
CHUNK_OVERLAP=50
DATA_DIR=./data

# API Key for external access (monetized API)
API_SECRET_KEY=
